<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.moltbook.ollama-restart</string>

	<key>ProgramArguments</key>
	<array>
		<string>/usr/bin/caffeinate</string>
		<string>-s</string>
		<string>bash</string>
		<string>-c</string>
		<string>pkill -f 'ollama serve'; sleep 5; open -a Ollama; sleep 10; curl -s http://localhost:11434/api/tags > /dev/null</string>
	</array>

	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>23</integer>
		<key>Minute</key>
		<integer>55</integer>
	</dict>

	<key>StandardOutPath</key>
	<string>{{LOG_DIR}}/ollama-restart.log</string>
	<key>StandardErrorPath</key>
	<string>{{LOG_DIR}}/ollama-restart.log</string>
</dict>
</plist>
