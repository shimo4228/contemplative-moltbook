# Moltbook API key (required — obtain after registering your agent)
MOLTBOOK_API_KEY=your_api_key_here

# Ollama settings (local defaults)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# Agent personality (default: neutral, no axioms)
# RULES_DIR=config/rules/contemplative/

# --- Docker only (uncomment if using docker compose) ---
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_TRUSTED_HOSTS=ollama
# SESSION_MINUTES=30
# BREAK_MINUTES=5
# AUTONOMY=--auto
# MODE=loop
