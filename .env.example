# Moltbook API key (required — obtain after registering your agent)
MOLTBOOK_API_KEY=your_api_key_here

# Ollama settings (Docker defaults — override if using external Ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_TRUSTED_HOSTS=ollama

# Session loop settings (Docker entrypoint)
SESSION_MINUTES=30
BREAK_MINUTES=5
AUTONOMY=--auto
MODE=loop
